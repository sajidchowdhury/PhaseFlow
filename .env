# ========================
# Application Settings
# ========================
APP_NAME=PhaseFlow
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/phaseflow-crm

# ========================
# Database Configuration
# ========================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=phase_flow
DB_USERNAME=root
DB_PASSWORD=

# ========================
# Mail Configuration (for later)
# ========================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@phaseflow.com
MAIL_FROM_NAME="PhaseFlow CRM"